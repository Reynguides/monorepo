<Window x:Class="Reyn.Desktop.Views.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Reyn.Desktop.ViewModels.Overlay;assembly=Reyn.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:OverlayViewModel}"
        mc:Ignorable="d"
        Title="Reyn Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowState="Maximized"
        AutomationProperties.AutomationId="OverlayWindow">
    <!-- The click-through window covers the desktop so BG3 can paint
         underneath. All real content sits in a single bottom-right HUD card. -->
    <Grid>
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Background="#CC1B1B22"
                BorderBrush="#FF3A3A4A"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18,14"
                Width="380"
                Tag="OverlayHud">
            <StackPanel>
                <!-- Header row: session timer + brand mark -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Reyn"
                               FontWeight="SemiBold"
                               FontSize="18"
                               Foreground="#FFE2A537"
                               AutomationProperties.AutomationId="OverlayBrand"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding SessionTimer}"
                               FontFamily="Consolas, Cascadia Mono"
                               FontSize="16"
                               Foreground="#FFE6E6F0"
                               VerticalAlignment="Center"
                               AutomationProperties.AutomationId="OverlaySessionTimer"/>
                </Grid>

                <!-- Party HP rings strip -->
                <ItemsControl ItemsSource="{Binding PartyRings}"
                              Margin="0,0,0,12"
                              AutomationProperties.AutomationId="OverlayPartyRings">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="44" Height="44">
                                    <!-- Background ring (full circle) -->
                                    <Ellipse Stroke="#FF3A3A4A" StrokeThickness="4"/>
                                    <!-- HP fill: a simple rectangular bar at the bottom for legibility
                                         in the screenshot. Phase 11 can replace with an arc segment. -->
                                    <Grid>
                                        <Rectangle Height="6"
                                                   VerticalAlignment="Bottom"
                                                   Fill="#FF3A3A4A"
                                                   Margin="4,0"/>
                                        <Rectangle Height="6"
                                                   VerticalAlignment="Bottom"
                                                   HorizontalAlignment="Left"
                                                   Fill="#FF6BB07A"
                                                   Margin="4,0,4,0"
                                                   Width="{Binding Fraction, Converter={StaticResource FractionToWidth}, ConverterParameter=36}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Hp}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#FFE6E6F0"/>
                                </Grid>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Foreground="#FFB4B4C7"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="60"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Last-event ticker -->
                <Border Background="#220F0F14"
                        CornerRadius="6"
                        Padding="10,8">
                    <ItemsControl ItemsSource="{Binding Ticker}"
                                  AutomationProperties.AutomationId="OverlayTicker">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Time}"
                                               Foreground="#FF6C6C82"
                                               FontFamily="Consolas, Cascadia Mono"
                                               FontSize="11"
                                               Width="64"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               Foreground="#FFE6E6F0"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
