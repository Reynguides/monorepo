<Window x:Class="Reyn.Desktop.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Width="420" Height="220"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Border Background="#FF1B1B22" CornerRadius="14" BorderBrush="#FF3A3A4A" BorderThickness="1">
        <Grid Margin="32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Reyn"
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="#FFE6E6F0"
                       HorizontalAlignment="Left"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,8,0,0">
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Background="#22FFFFFF"
                             Foreground="#FF8A6AFA"
                             BorderThickness="0"/>
                <TextBlock x:Name="StatusText"
                           Text="{Binding StatusMessage}"
                           Foreground="#FFB4B4C7"
                           FontSize="13"
                           Margin="0,10,0,0"
                           AutomationProperties.AutomationId="SplashStatus"/>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="{Binding Version, StringFormat='v{0}'}"
                       Foreground="#FF6C6C82"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       AutomationProperties.AutomationId="SplashVersion"/>
        </Grid>
    </Border>
</Window>
