<UserControl x:Class="Reyn.Desktop.Views.Shell.Pages.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Reyn.Desktop.Views.Shell.Controls"
             xmlns:vm="clr-namespace:Reyn.Desktop.ViewModels.Shell;assembly=Reyn.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:EventsViewModel}"
             mc:Ignorable="d">
    <Grid Margin="{StaticResource ThicknessLg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   Style="{StaticResource TitleText}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   AutomationProperties.AutomationId="PageTitle"/>
        <TextBlock Grid.Row="1"
                   Text="{Binding Subtitle}"
                   Style="{StaticResource BodyText}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,16"
                   TextWrapping="Wrap"/>

        <!-- FILTER BAR: type chips, date range, source dropdown, clear -->
        <Border Grid.Row="2"
                Style="{StaticResource StatCardStyle}"
                Margin="0,0,0,12"
                AutomationProperties.AutomationId="EventsFilterBar">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding TypeChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton Content="{Binding DisplayLabel}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Margin="0,0,8,8"
                                          Padding="10,4"
                                          Background="{DynamicResource ElevatedSurfaceBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          BorderBrush="{DynamicResource DividerBrush}"
                                          BorderThickness="1"
                                          FontSize="12">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="From" Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <DatePicker Grid.Column="1"
                                SelectedDate="{Binding FromUtc, Mode=TwoWay}"
                                Width="140"
                                AutomationProperties.AutomationId="EventsFromDate"/>

                    <TextBlock Grid.Column="2" Text="To" Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Margin="14,0,6,0"/>
                    <DatePicker Grid.Column="3"
                                SelectedDate="{Binding ToUtc, Mode=TwoWay}"
                                Width="140"
                                AutomationProperties.AutomationId="EventsToDate"/>

                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding Sources}"
                              SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                              Width="220"
                              Margin="14,0,0,0"
                              HorizontalAlignment="Left"
                              AutomationProperties.AutomationId="EventsSourceDropdown"/>

                    <Button Grid.Column="5"
                            Content="Clear"
                            Command="{Binding ClearCommand}"
                            Padding="14,4"
                            Background="Transparent"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            AutomationProperties.AutomationId="EventsClearFilters"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <controls:PageStateControl/>

            <Grid Visibility="{Binding State, Converter={StaticResource ReadyStateToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8"
                            AutomationProperties.AutomationId="EventsVisibleCount">
                    <TextBlock Text="{Binding VisibleCount}"
                               Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text=" events shown"
                               Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              AutomationProperties.AutomationId="EventsList">
                    <ItemsControl ItemsSource="{Binding Events}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding OccurredAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Type}"
                                                   Style="{StaticResource BodyText}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PayloadJson}"
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="12,0,0,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Source}"
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
