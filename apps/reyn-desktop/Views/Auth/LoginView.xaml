<UserControl x:Class="Reyn.Desktop.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Background="#FF3A1F22"
                BorderBrush="#FFC4585F"
                BorderThickness="1"
                Padding="12,8"
                CornerRadius="6"
                Margin="0,0,0,14"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FFFDD9DC"
                       FontSize="13"
                       TextWrapping="Wrap"
                       AutomationProperties.AutomationId="LoginErrorBanner"/>
        </Border>

        <TextBlock Text="Email"
                   Foreground="#FFB4B4C7"
                   FontSize="12"
                   Margin="0,0,0,4"/>
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.AutomationId="LoginEmail"
                 Padding="10,8"
                 Background="#FF222230"
                 Foreground="#FFE6E6F0"
                 CaretBrush="#FFE6E6F0"
                 BorderBrush="#FF3A3A4A"
                 BorderThickness="1"
                 FontSize="14"/>

        <TextBlock Text="Password"
                   Foreground="#FFB4B4C7"
                   FontSize="12"
                   Margin="0,14,0,4"/>
        <PasswordBox x:Name="PasswordField"
                     PasswordChanged="OnPasswordChanged"
                     AutomationProperties.AutomationId="LoginPassword"
                     Padding="10,8"
                     Background="#FF222230"
                     Foreground="#FFE6E6F0"
                     BorderBrush="#FF3A3A4A"
                     BorderThickness="1"
                     FontSize="14"/>

        <Button Content="Sign in"
                Command="{Binding SubmitCommand}"
                IsEnabled="{Binding CanSubmit}"
                AutomationProperties.AutomationId="LoginSubmit"
                Margin="0,22,0,0"
                Padding="0,10"
                Background="#FF8A6AFA"
                Foreground="White"
                FontWeight="SemiBold"
                BorderThickness="0"
                FontSize="14"/>
    </StackPanel>
</UserControl>
