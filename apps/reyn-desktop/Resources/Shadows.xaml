<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Drop shadow effects used to lift surfaces above the base canvas.
        Reused on the nav rail border and card surfaces. Kept theme-neutral
        (the shadow color works on both light + dark canvases).
    -->
    <DropShadowEffect x:Key="ShadowSm"
                      BlurRadius="6"
                      ShadowDepth="1"
                      Opacity="0.35"
                      Color="Black"/>

    <DropShadowEffect x:Key="ShadowMd"
                      BlurRadius="16"
                      ShadowDepth="2"
                      Opacity="0.4"
                      Color="Black"/>

    <DropShadowEffect x:Key="ShadowLg"
                      BlurRadius="32"
                      ShadowDepth="4"
                      Opacity="0.45"
                      Color="Black"/>

</ResourceDictionary>
