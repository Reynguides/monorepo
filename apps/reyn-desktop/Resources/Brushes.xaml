<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Palette swatches. These are the *raw colors* — the semantic brush
        names that views bind to live in Reyn.Dark.xaml / Reyn.Light.xaml and
        re-export the swatches under role-based keys (BackgroundBrush,
        ForegroundBrush, AccentBrush, …). Views never bind to the swatch
        keys directly — that would defeat theming.
    -->

    <!-- Dark palette -->
    <Color x:Key="DarkBg0">#FF0F0F14</Color>
    <Color x:Key="DarkBg1">#FF15151B</Color>
    <Color x:Key="DarkBg2">#FF1B1B22</Color>
    <Color x:Key="DarkBg3">#FF222230</Color>
    <Color x:Key="DarkBorder">#FF3A3A4A</Color>
    <Color x:Key="DarkFg0">#FFE6E6F0</Color>
    <Color x:Key="DarkFg1">#FFB4B4C7</Color>
    <Color x:Key="DarkFg2">#FF6C6C82</Color>

    <!-- Light palette (parchment + warm browns) -->
    <Color x:Key="LightBg0">#FFFBF4E1</Color>
    <Color x:Key="LightBg1">#FFF5EBD0</Color>
    <Color x:Key="LightBg2">#FFEFE0BD</Color>
    <Color x:Key="LightBg3">#FFE5D3A6</Color>
    <Color x:Key="LightBorder">#FFB59465</Color>
    <Color x:Key="LightFg0">#FF2A1F0E</Color>
    <Color x:Key="LightFg1">#FF5A4622</Color>
    <Color x:Key="LightFg2">#FF8E764A</Color>

    <!-- Brand accents — shared across themes -->
    <Color x:Key="Amber">#FFE2A537</Color>
    <Color x:Key="AmberMuted">#FFB1812B</Color>
    <Color x:Key="DangerRed">#FFC4585F</Color>
    <Color x:Key="DangerRedBg">#FF3A1F22</Color>
    <Color x:Key="WarningGold">#FFE6C547</Color>
    <Color x:Key="SuccessGreen">#FF6BB07A</Color>

</ResourceDictionary>
