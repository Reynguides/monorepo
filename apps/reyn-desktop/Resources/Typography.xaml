<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Reyn type scale. Single sans-serif family (Segoe UI ships with
        Windows so no font asset bloat); weight + size variation builds the
        hierarchy. Values are unitless DIPs.
    -->
    <FontFamily x:Key="UiFont">Segoe UI, Calibri, Arial</FontFamily>
    <FontFamily x:Key="DisplayFont">Segoe UI Semibold, Calibri, Arial</FontFamily>

    <sys:Double x:Key="FontSizeDisplay">32</sys:Double>
    <sys:Double x:Key="FontSizeTitle">22</sys:Double>
    <sys:Double x:Key="FontSizeHeading">16</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>

    <Style x:Key="DisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="HeadingText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
    </Style>

</ResourceDictionary>
