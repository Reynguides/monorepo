<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Semantic brush keys. Views bind to these (e.g.
        `Background="{DynamicResource BackgroundBrush}"`); switching themes
        swaps which palette the keys resolve to. Per ADR-0009 we keep the
        palette tight (one accent family) so the dark + light themes feel
        like the *same product*, not different skins.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Brushes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="BackgroundBrush"            Color="{StaticResource DarkBg0}"/>
    <SolidColorBrush x:Key="SurfaceBrush"               Color="{StaticResource DarkBg1}"/>
    <SolidColorBrush x:Key="ElevatedSurfaceBrush"       Color="{StaticResource DarkBg2}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush"       Color="{StaticResource DarkBg3}"/>
    <SolidColorBrush x:Key="DividerBrush"               Color="{StaticResource DarkBorder}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"           Color="{StaticResource DarkFg0}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"         Color="{StaticResource DarkFg1}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"          Color="{StaticResource DarkFg2}"/>

    <SolidColorBrush x:Key="AccentBrush"                Color="{StaticResource Amber}"/>
    <SolidColorBrush x:Key="AccentMutedBrush"           Color="{StaticResource AmberMuted}"/>
    <SolidColorBrush x:Key="DangerBrush"                Color="{StaticResource DangerRed}"/>
    <SolidColorBrush x:Key="DangerBackgroundBrush"      Color="{StaticResource DangerRedBg}"/>
    <SolidColorBrush x:Key="SuccessBrush"               Color="{StaticResource SuccessGreen}"/>
    <SolidColorBrush x:Key="WarningBrush"               Color="{StaticResource WarningGold}"/>

</ResourceDictionary>
