# Visual Studio / Rider
.vs/
.idea/

# Build output
bin/
obj/

# User files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet legacy `packages/` folder is no longer used (CPM is in
# Directory.Packages.props). `packages/` is now the pnpm workspace dir;
# files there should be tracked. Only the per-package node_modules is
# ignored (via the global rule below).

# Logs
*.log

# Local databases
*.db
*.db-journal
*.db-shm
*.db-wal

# Test / coverage artefacts
coverage/
# tools/coverage/ holds the cobertura runsettings file checked into
# the repo (used by the CI .NET job). The broad `coverage/` pattern
# above would otherwise swallow it.
!tools/coverage/
coverage-out/
TestResults/
**/coverage.cobertura.xml
**/coverage.opencover.xml
tools/coverage-report/
/coverage-report/

# Node / pnpm
node_modules/
.pnpm-store/

# Wrangler / Cloudflare local dev
.wrangler/
.dev.vars
.dev.vars.*

# Local scratch tooling (one-off fill/index scripts, notes, checkpoints; not product code)
*.local.mjs
*.local.txt
*.local.json

# Claude Code local agent config (machine-local; not shared)
.claude/

# Local secrets / env
.env
.env.local
.env.*.local

# OS detritus
Thumbs.db
.DS_Store
